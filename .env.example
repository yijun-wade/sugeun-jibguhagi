# ── 국토교통부 실거래가 API (data.go.kr) ───────────────────────────────────
# https://www.data.go.kr → 국토교통부_아파트매매 실거래 상세 자료
MOLIT_API_KEY=your_key_here

# ── 네이버 개발자센터 (블로그/카페/뉴스/지식인 검색) ──────────────────────
# https://developers.naver.com → 애플리케이션 등록 → 검색 API
NAVER_CLIENT_ID=your_client_id_here
NAVER_CLIENT_SECRET=your_client_secret_here

# ── Anthropic Claude API (AI 수근수근 요약) ────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_key_here

# ── 카카오 지도 JavaScript API (지도 표시) ──────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# Kakao Developers 콘솔에서 플랫폼 > Web → 사이트 도메인 등록 필수
VITE_KAKAO_JS_KEY=your_kakao_js_key_here

# ── Google AdSense ──────────────────────────────────────────────────────────
# https://adsense.google.com → 사이트 추가 → 심사 통과 후 활성화
# 클라이언트 ID: "ca-pub-XXXXXXXXXXXXXXXXX" 형식
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX
# 광고 슬롯 ID: AdSense 콘솔 → 광고 단위 만들기 → 슬롯 ID
VITE_ADSENSE_SLOT_RESULTS=XXXXXXXXXX
