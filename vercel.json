{
  "buildCommand": "npx vite build",
  "devCommand": "npx vite --port $PORT",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/trade.js":    { "regions": ["icn1"] },
    "api/search.js":   { "regions": ["icn1"] },
    "api/geocode.js":  { "regions": ["icn1"] },
    "api/stories.js":  { "regions": ["icn1"] },
    "api/vibe.js":     { "regions": ["icn1"], "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
